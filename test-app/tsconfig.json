{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./*"],
      "xpecto-shield": ["../src/index.ts"],
      "xpecto-shield/core": ["../src/core/index.ts"],
      "xpecto-shield/middleware": ["../src/middleware/index.ts"],
      "xpecto-shield/api": ["../src/api/index.ts"],
      "xpecto-shield/dashboard": ["../src/dashboard/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "../src/**/*.ts", "../src/**/*.tsx"],
  "exclude": ["node_modules"]
}
